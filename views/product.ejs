<%- include('partials/header') %>

<% 
  const isDiscounted = p.sale_price && p.sale_price < p.price;
  const discountPercentage = isDiscounted ? Math.round(((p.price - p.sale_price) / p.price) * 100) : 0;
  const displayImages = (p.images && p.images.length > 0) ? p.images : [p.main_image];
  const unitPrice = p.sale_price || p.price;
%>

<!-- Breadcrumb Navigation -->
<nav aria-label="Breadcrumb" class="bg-stone-100/80 border-b border-stone-300 py-3.5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-stone-700 flex items-center gap-2 overflow-x-auto whitespace-nowrap font-medium">
        <a href="/" class="hover:text-emerald-900 transition-colors flex items-center gap-1">
            <i data-lucide="home" class="w-3.5 h-3.5 text-stone-500"></i> Home
        </a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-stone-400 shrink-0"></i>
        <a href="/shop" class="hover:text-emerald-900 transition-colors">Shop Harvests</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-stone-400 shrink-0"></i>
        <a href="/shop?category=<%= p.category_slug %>" class="hover:text-emerald-900 transition-colors capitalize"><%= p.category_name %></a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-stone-400 shrink-0"></i>
        <span class="text-stone-950 font-bold truncate max-w-[240px]"><%= p.name %></span>
    </div>
</nav>

<!-- Main Product View -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 space-y-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
        
        <!-- LEFT COLUMN: Product Image Gallery (lg:col-span-6) -->
        <div class="lg:col-span-6 space-y-5">
            <!-- Main Featured Boxed Image Container (Shopify Style) -->
            <div class="bg-stone-50/90 border-2 border-stone-200/80 rounded-2xl p-0 relative aspect-square min-h-[440px] sm:min-h-[500px] lg:min-h-[540px] w-full flex items-center justify-center shadow-xs overflow-hidden group">
                
                <!-- Quality Stamps -->
                <div class="absolute top-3 left-3 z-20 flex flex-col gap-1.5">
                    <span class="bg-emerald-900 text-amber-300 text-[10px] font-extrabold px-2.5 py-1 rounded-lg border border-emerald-800 shadow-xs flex items-center gap-1">
                        <i data-lucide="shield-check" class="w-3.5 h-3.5 text-amber-300"></i> 100% Single-Origin J&K
                    </span>
                    <% if (isDiscounted) { %>
                        <span class="bg-rose-100 text-rose-950 text-[10px] font-extrabold px-2.5 py-1 rounded-lg border border-rose-300 shadow-xs flex items-center gap-1">
                            <i data-lucide="sparkles" class="w-3.5 h-3.5 text-rose-700"></i> Save <%= discountPercentage %>%
                        </span>
                    <% } %>
                </div>

                <div class="absolute top-3 right-3 z-20">
                    <span class="bg-amber-100 text-amber-950 text-[10px] font-bold px-2.5 py-1 rounded-lg border border-amber-300 shadow-xs">
                        Direct Farm Harvest
                    </span>
                </div>

                <!-- Main Display Image -->
                <img id="main-product-img" src="<%= p.main_image || displayImages[0] %>" alt="<%= p.name %>" class="w-full h-full object-contain p-0 transition-transform duration-300 drop-shadow-md" />
            </div>

            <!-- Image Thumbnails Grid (Small Box Row directly below main image) -->
            <div class="space-y-2.5 w-full">
                <span class="text-[11px] font-extrabold text-stone-700 uppercase tracking-wider block text-center">Click Small Box to Switch View:</span>
                <div class="flex flex-wrap items-center justify-center gap-3.5">
                    <% displayImages.forEach((img, idx) => { %>
                        <button type="button" onclick="selectProductImage(<%= idx %>, '<%= img %>', this)" class="thumbnail-btn w-20 h-20 sm:w-24 sm:h-24 bg-white border-2 <%= idx === 0 ? 'border-emerald-800 ring-2 ring-emerald-600/30' : 'border-stone-300 hover:border-emerald-600' %> rounded-xl overflow-hidden p-2 transition-all cursor-pointer shadow-2xs flex items-center justify-center shrink-0">
                            <img src="<%= img %>" alt="<%= p.name %> view <%= idx + 1 %>" class="max-h-full max-w-full object-contain rounded-md" />
                        </button>
                    <% }); %>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Purchase Details & Form (lg:col-span-6) -->
        <div class="lg:col-span-6 space-y-6">
            
            <!-- Product Title & Category -->
            <div class="space-y-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <span class="bg-emerald-100 text-emerald-950 border border-emerald-300 text-xs font-bold px-3 py-1 rounded-lg uppercase tracking-wider flex items-center gap-1.5">
                        <i data-lucide="leaf" class="w-3.5 h-3.5 text-emerald-700"></i> <%= p.category_name || 'Kashmiri Organic Produce' %>
                    </span>
                    <span class="text-xs font-bold text-stone-900 bg-stone-100 border border-stone-300 px-3 py-1 rounded-lg flex items-center gap-1.5 font-mono">
                        <i data-lucide="shield-check" class="w-3.5 h-3.5 text-emerald-800"></i> FSSAI: 21024012000212
                    </span>
                </div>

                <h1 class="font-display font-extrabold text-2xl sm:text-3xl lg:text-4xl text-stone-900 leading-snug">
                    <%= p.name %>
                </h1>

                <!-- Rating and SKU -->
                <div class="flex flex-wrap items-center justify-between gap-3 border-b-2 border-stone-200 pb-4 text-xs">
                    <div class="flex items-center gap-2">
                        <div class="flex items-center text-amber-500">
                            <i data-lucide="star" class="w-4 h-4 fill-amber-500"></i>
                            <i data-lucide="star" class="w-4 h-4 fill-amber-500"></i>
                            <i data-lucide="star" class="w-4 h-4 fill-amber-500"></i>
                            <i data-lucide="star" class="w-4 h-4 fill-amber-500"></i>
                            <i data-lucide="star" class="w-4 h-4 fill-amber-500"></i>
                        </div>
                        <span class="font-extrabold text-stone-900 text-sm">4.9 / 5.0</span>
                        <a href="#reviews" class="text-emerald-800 hover:underline font-bold text-xs">(<%= (reviews_list || []).length > 0 ? (reviews_list || []).length : 48 %> Buyer Reviews)</a>
                    </div>
                    
                    <span class="text-stone-700 font-mono text-xs font-semibold">SKU: <%= p.sku %></span>
                </div>
            </div>

            <!-- Price & Variant Selection Box -->
            <div class="bg-white border-2 border-stone-300 rounded-2xl p-6 shadow-sm space-y-5">
                
                <!-- Price Display -->
                <div class="flex flex-wrap items-baseline justify-between gap-3 border-b border-stone-200 pb-4">
                    <div>
                        <span class="text-xs text-stone-600 uppercase font-bold tracking-wider block">Direct Farm Price:</span>
                        <div class="flex items-baseline gap-3 mt-1">
                            <span id="display-sale-price" class="text-3xl sm:text-4xl font-extrabold text-stone-900 font-display">₹<%= (p.sale_price || p.price).toFixed(2) %></span>
                            <% if (isDiscounted) { %>
                                <span id="display-mrp" class="text-base sm:text-lg text-stone-500 line-through font-mono">₹<%= p.price.toFixed(2) %></span>
                                <span id="display-save-tag" class="bg-rose-100 text-rose-950 text-xs font-extrabold px-2.5 py-1 rounded-lg border border-rose-300">
                                    Save ₹<%= (p.price - p.sale_price).toFixed(0) %>
                                </span>
                            <% } %>
                        </div>
                    </div>
                    <span class="text-xs font-bold text-emerald-950 bg-emerald-50 border border-emerald-300 px-3 py-1.5 rounded-lg">
                        ✓ GST & Local Taxes Included
                    </span>
                </div>

                <!-- Weight Pack Selection -->
                <div class="space-y-2.5">
                    <label class="text-xs font-bold text-stone-900 uppercase tracking-wider block">
                        Select Pack Net Weight Variant:
                    </label>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5" id="variant-selector-grid">
                        <button type="button" onclick="updateVariant('500 Grams Pack', <%= unitPrice %>, <%= p.price %>, this)" class="variant-btn border-2 border-emerald-800 bg-emerald-50 text-emerald-950 font-extrabold text-xs p-3 rounded-xl shadow-2xs text-left cursor-pointer transition-all">
                            <div class="flex items-center justify-between">
                                <span>500 Grams Pack</span>
                                <i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-800 shrink-0"></i>
                            </div>
                            <span class="text-xs text-emerald-900 font-extrabold font-mono block mt-1">₹<%= unitPrice.toFixed(2) %></span>
                        </button>

                        <button type="button" onclick="updateVariant('1 KG Family Pack', <%= (unitPrice * 1.9).toFixed(2) %>, <%= (p.price * 1.9).toFixed(2) %>, this)" class="variant-btn border-2 border-stone-300 hover:border-emerald-600 bg-white text-stone-900 font-bold text-xs p-3 rounded-xl shadow-2xs text-left cursor-pointer transition-all">
                            <div class="flex items-center justify-between">
                                <span>1 KG Family Pack</span>
                            </div>
                            <span class="text-xs text-stone-700 font-extrabold font-mono block mt-1">₹<%= (unitPrice * 1.9).toFixed(2) %></span>
                        </button>

                        <button type="button" onclick="updateVariant('250 Grams Trial', <%= (unitPrice * 0.55).toFixed(2) %>, <%= (p.price * 0.55).toFixed(2) %>, this)" class="variant-btn border-2 border-stone-300 hover:border-emerald-600 bg-white text-stone-900 font-bold text-xs p-3 rounded-xl shadow-2xs text-left cursor-pointer transition-all col-span-2 sm:col-span-1">
                            <div class="flex items-center justify-between">
                                <span>250 Grams Trial</span>
                            </div>
                            <span class="text-xs text-stone-700 font-extrabold font-mono block mt-1">₹<%= (unitPrice * 0.55).toFixed(2) %></span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Buy Now Action Form -->
            <form action="/checkout" method="POST" class="space-y-4">
                <input type="hidden" name="direct_buy" value="1">
                <input type="hidden" name="product_id" value="<%= p.id %>">
                <input type="hidden" id="selected-weight-input" name="weight_variant" value="500 Grams Pack">
                <input type="hidden" id="selected-price-input" name="unit_price" value="<%= unitPrice %>">
                
                <div class="flex flex-col sm:flex-row items-stretch gap-3">
                    <!-- Quantity Stepper -->
                    <div class="flex items-center justify-between border-2 border-stone-300 rounded-xl bg-stone-100 p-1.5 shrink-0 sm:w-36 shadow-2xs">
                        <button type="button" onclick="adjustQty(-1)" class="w-9 h-9 rounded-lg bg-white border border-stone-300 text-stone-900 font-black text-lg flex items-center justify-center hover:bg-stone-200 cursor-pointer shadow-2xs transition-colors">-</button>
                        <input type="text" id="qty-input" name="quantity" value="1" readonly class="w-12 text-center text-base font-extrabold border-none text-stone-900 bg-transparent focus:outline-none select-none font-mono">
                        <button type="button" onclick="adjustQty(1)" class="w-9 h-9 rounded-lg bg-white border border-stone-300 text-stone-900 font-black text-lg flex items-center justify-center hover:bg-stone-200 cursor-pointer shadow-2xs transition-colors">+</button>
                    </div>

                    <!-- Buy Now Primary Button -->
                    <button type="submit" class="flex-grow bg-emerald-900 hover:bg-emerald-950 text-amber-300 font-display font-extrabold text-base py-4 px-6 rounded-xl shadow-md hover:shadow-lg transition-all flex items-center justify-center gap-3 cursor-pointer border border-emerald-800">
                        <i data-lucide="zap" class="w-5 h-5 text-amber-300 fill-amber-300"></i>
                        <span class="tracking-wide text-amber-300 uppercase">BUY NOW &mdash; ₹<span id="btn-price-display"><%= unitPrice.toFixed(2) %></span></span>
                    </button>
                </div>
            </form>

            <!-- Direct WhatsApp Order Action -->
            <div class="bg-emerald-50 border-2 border-emerald-200 rounded-xl p-4 flex items-center justify-between gap-3 text-emerald-950">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">💬</span>
                    <div>
                        <p class="font-bold text-xs text-emerald-950">Prefer Direct WhatsApp Ordering?</p>
                        <p class="text-[11px] text-emerald-800 font-medium">Chat directly with Founder Dr. Deen Mohd</p>
                    </div>
                </div>
                <a href="https://wa.me/916006049016?text=Hello%20Deenz%20Organics,%20I%20want%20to%20order%20<%= encodeURIComponent(p.name) %>" target="_blank" rel="noopener" class="bg-emerald-900 hover:bg-emerald-950 text-amber-300 font-bold text-xs px-4 py-2.5 rounded-lg transition-colors shrink-0 flex items-center gap-1.5 border border-emerald-800">
                    Order via WhatsApp
                </a>
            </div>

            <!-- E-Commerce Marketplaces Availability -->
            <div class="space-y-2.5 pt-2">
                <span class="text-xs font-black uppercase tracking-wider text-black block">
                    ALSO AVAILABLE ON MARKETPLACES:
                </span>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <a href="https://www.amazon.in/Naturally-Sun-Dried-Preservatives-DEENZ-ORGANICS/dp/B0H8M823KY/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between bg-black hover:bg-stone-900 text-white font-bold text-xs py-3.5 px-4 rounded-xl shadow-xs border border-black transition-all">
                        <div class="flex items-center gap-2.5">
                            <span class="bg-amber-400 text-black text-[11px] font-black px-2 py-0.5 rounded uppercase tracking-wider">AMAZON</span>
                            <span class="text-xs text-white font-extrabold">Buy on Amazon</span>
                        </div>
                        <i data-lucide="external-link" class="w-4 h-4 text-white"></i>
                    </a>

                    <a href="https://www.flipkart.com/search?q=Deenz+Organics" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between bg-black hover:bg-stone-900 text-white font-bold text-xs py-3.5 px-4 rounded-xl shadow-xs border border-black transition-all">
                        <div class="flex items-center gap-2.5">
                            <span class="bg-amber-400 text-black text-[11px] font-black px-2 py-0.5 rounded uppercase tracking-wider italic">FLIPKART</span>
                            <span class="text-xs text-white font-extrabold">Buy on Flipkart</span>
                        </div>
                        <i data-lucide="external-link" class="w-4 h-4 text-white"></i>
                    </a>
                </div>
            </div>

        </div>
    </div>

    <!-- FULL PAGE DETAILED SECTIONS -->
    <div id="details" class="pt-8 border-t-2 border-stone-300 space-y-8">
        
        <!-- MAIN DETAILS CONTENT & FLOATING SIDEBAR CONTAINER -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- Left 8 Cols: Full Page Stacked Sections -->
            <div class="lg:col-span-8 space-y-12">
                
                <!-- Section 1: Overview & Harvest Story & Benefits -->
                <div id="harvest-story" class="space-y-6">
                    <div class="flex items-center gap-3 border-b-2 border-emerald-900/20 pb-3">
                        <i data-lucide="leaf" class="w-6 h-6 text-emerald-800"></i>
                        <h2 class="font-display font-extrabold text-xl text-stone-900 tracking-tight">Harvest Story & Benefits</h2>
                    </div>

                    <div class="bg-white border-2 border-stone-300 rounded-2xl p-6 sm:p-8 space-y-4 shadow-2xs">
                        <h3 class="font-display font-extrabold text-lg text-stone-900 border-b border-stone-200 pb-3">
                            Pure Kashmir Valley Harvest Story
                        </h3>
                        <p class="text-xs sm:text-sm text-stone-800 leading-relaxed">
                            <%= p.description %>
                        </p>
                    </div>

                    <% if (p.benefits && p.benefits.length > 0) { %>
                        <div class="space-y-4">
                            <h3 class="font-display font-bold text-base text-stone-900">Key Health & Nutritional Benefits</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <% p.benefits.forEach(b => { %>
                                    <div class="flex items-start gap-3 bg-stone-50 border border-stone-300 p-4 rounded-xl shadow-2xs">
                                        <i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-800 shrink-0 mt-0.5"></i>
                                        <span class="text-xs text-stone-900 font-semibold leading-relaxed"><%= b %></span>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Section 2: Specifications & Usage -->
                <div id="specifications" class="space-y-6 pt-4 border-t-2 border-stone-200">
                    <div class="flex items-center gap-3 border-b-2 border-emerald-900/20 pb-3">
                        <i data-lucide="clipboard-list" class="w-6 h-6 text-emerald-800"></i>
                        <h2 class="font-display font-extrabold text-xl text-stone-900 tracking-tight">Specifications & Usage</h2>
                    </div>

                    <% if (p.specifications) { %>
                        <div class="bg-white border-2 border-stone-300 rounded-2xl overflow-hidden shadow-2xs">
                            <h3 class="font-display font-bold text-base text-stone-900 p-5 bg-stone-100 border-b border-stone-300">
                                Commodity & Quality Specifications
                            </h3>
                            <table class="w-full text-left text-xs text-stone-800">
                                <tbody class="divide-y divide-stone-200">
                                    <% Object.entries(p.specifications).forEach(([key, val]) => { %>
                                        <tr class="hover:bg-stone-50">
                                            <td class="p-4 bg-stone-100/70 font-bold text-stone-900 w-1/3"><%= key %></td>
                                            <td class="p-4 text-stone-800 font-mono"><%= val %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="bg-white p-6 border-2 border-stone-300 rounded-2xl space-y-3">
                            <h4 class="font-bold text-xs uppercase text-emerald-900 tracking-wider flex items-center gap-2">
                                <i data-lucide="utensils" class="w-4 h-4 text-emerald-800"></i> How to Consume
                            </h4>
                            <p class="text-xs text-stone-800 leading-relaxed">
                                <%= p.how_to_use %>
                            </p>
                        </div>

                        <div class="bg-white p-6 border-2 border-stone-300 rounded-2xl space-y-3">
                            <h4 class="font-bold text-xs uppercase text-amber-950 tracking-wider flex items-center gap-2">
                                <i data-lucide="leaf" class="w-4 h-4 text-amber-800"></i> Ingredients
                            </h4>
                            <p class="text-xs text-stone-800 leading-relaxed font-mono">
                                <%= p.ingredients %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Q&A & Guarantee -->
                <div id="guarantee" class="space-y-6 pt-4 border-t-2 border-stone-200">
                    <div class="flex items-center gap-3 border-b-2 border-emerald-900/20 pb-3">
                        <i data-lucide="help-circle" class="w-6 h-6 text-emerald-800"></i>
                        <h2 class="font-display font-extrabold text-xl text-stone-900 tracking-tight">Q&A & Guarantee</h2>
                    </div>

                    <% if (p.faqs && p.faqs.length > 0) { %>
                        <div class="space-y-4">
                            <h3 class="font-display font-bold text-base text-stone-900">Frequently Asked Questions</h3>
                            <div class="space-y-3">
                                <% p.faqs.forEach(faq => { %>
                                    <div class="bg-white border-2 border-stone-300 rounded-2xl p-6 space-y-2">
                                        <h4 class="font-bold text-xs text-stone-900 flex items-center gap-2">
                                            <span class="bg-emerald-900 text-amber-300 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-mono shrink-0">Q</span>
                                            <%= faq.q %>
                                        </h4>
                                        <p class="text-xs text-stone-700 leading-relaxed pl-7">
                                            <%= faq.a %>
                                        </p>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>

                    <div class="bg-emerald-900 text-amber-300 rounded-2xl p-6 space-y-3 border-2 border-emerald-800 shadow-md">
                        <div class="flex items-center gap-3">
                            <i data-lucide="shield-check" class="w-6 h-6 text-amber-300 shrink-0"></i>
                            <h4 class="font-extrabold text-sm text-amber-300 uppercase tracking-wider">Our 100% Crunch & Freshness Guarantee</h4>
                        </div>
                        <p class="text-xs text-stone-200 leading-relaxed">
                            If your organic harvest arrives soft, stale, or lacks its characteristic Kashmiri mountain crunch, call our founder direct helpline at <strong class="text-amber-300 font-mono">+91 60060 49016</strong> for an immediate replacement or full refund.
                        </p>
                    </div>
                </div>

                <!-- Section 4: Buyer Reviews -->
                <div id="reviews" class="space-y-6 pt-4 border-t-2 border-stone-200">
                    <div class="flex items-center gap-3 border-b-2 border-emerald-900/20 pb-3">
                        <i data-lucide="star" class="w-6 h-6 text-amber-500 fill-amber-500"></i>
                        <h2 class="font-display font-extrabold text-xl text-stone-900 tracking-tight">Buyer Reviews (<%= (reviews_list || []).length %>)</h2>
                    </div>
                    
                    <% if (review_message) { %>
                        <div class="p-4 bg-emerald-50 border-2 border-emerald-300 text-emerald-950 text-xs rounded-xl flex items-center gap-3 font-bold">
                            <i data-lucide="check-circle" class="w-5 h-5 text-emerald-800"></i>
                            <span><%= review_message %></span>
                        </div>
                    <% } %>

                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-stone-200 pb-3">
                        <h4 class="font-extrabold text-base text-stone-900">Verified Ratings (<%= (reviews_list || []).length %>)</h4>
                        
                        <!-- Star Filter Buttons -->
                        <div class="flex flex-wrap items-center gap-1.5" id="review-filter-buttons">
                            <button type="button" onclick="filterReviews('all', this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-emerald-900 text-amber-300 border border-emerald-800 shadow-2xs cursor-pointer">
                                All (<%= (reviews_list || []).length %>)
                            </button>
                            <button type="button" onclick="filterReviews(5, this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-stone-800 border border-stone-300 hover:bg-stone-100 cursor-pointer">
                                5 Stars ★
                            </button>
                            <button type="button" onclick="filterReviews(4, this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-stone-800 border border-stone-300 hover:bg-stone-100 cursor-pointer">
                                4 Stars ★
                            </button>
                            <button type="button" onclick="filterReviews(3, this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-stone-800 border border-stone-300 hover:bg-stone-100 cursor-pointer">
                                3 Stars ★
                            </button>
                            <button type="button" onclick="filterReviews(2, this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-stone-800 border border-stone-300 hover:bg-stone-100 cursor-pointer">
                                2 Stars ★
                            </button>
                            <button type="button" onclick="filterReviews(1, this)" class="review-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-stone-800 border border-stone-300 hover:bg-stone-100 cursor-pointer">
                                1 Star ★
                            </button>
                        </div>
                    </div>

                    <!-- Reviews Stream List -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="reviews-list-container">
                        <% (reviews_list || []).forEach((rev, rIdx) => { %>
                            <div data-rating="<%= rev.rating || 5 %>" class="review-card-item bg-white border-2 border-stone-300 rounded-2xl p-5 space-y-3 shadow-2xs flex flex-col justify-between <%= rIdx >= 10 ? 'hidden' : '' %>">
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-8 h-8 bg-emerald-900 text-amber-300 rounded-full flex items-center justify-center font-bold text-xs shrink-0">
                                                <%= (rev.author || 'AC').substring(0, 2).toUpperCase() %>
                                            </div>
                                            <div>
                                                <h5 class="font-bold text-xs text-stone-900"><%= rev.author %></h5>
                                                <p class="text-[10px] text-emerald-800 font-bold flex items-center gap-1">
                                                    <i data-lucide="check-circle" class="w-3 h-3 text-emerald-700"></i> Verified Buyer
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center text-amber-500">
                                            <% for (let i = 1; i <= 5; i++) { %>
                                                <i data-lucide="star" class="w-3.5 h-3.5 <%= i <= (rev.rating || 5) ? 'fill-amber-500 text-amber-500' : 'text-stone-300' %>"></i>
                                            <% } %>
                                        </div>
                                    </div>
                                    <p class="text-xs text-stone-800 leading-relaxed italic pt-1">
                                        "<%= rev.comment %>"
                                    </p>
                                </div>
                                <p class="text-[10px] text-stone-500 font-mono text-right pt-2 border-t border-stone-200"><%= rev.created_at %></p>
                            </div>
                        <% }); %>
                    </div>

                    <!-- Load More Reviews Button -->
                    <% if ((reviews_list || []).length > 10) { %>
                        <div class="text-center pt-2" id="load-more-reviews-box">
                            <button type="button" onclick="loadMoreReviews()" class="bg-white hover:bg-stone-100 border-2 border-stone-300 text-stone-900 font-extrabold text-xs px-6 py-3 rounded-xl transition-all shadow-2xs cursor-pointer inline-flex items-center gap-2">
                                <span>Load More Reviews (Showing <span id="visible-count-text">10</span> of <span id="total-count-text"><%= reviews_list.length %></span>)</span>
                                <i data-lucide="chevron-down" class="w-4 h-4 text-emerald-800"></i>
                            </button>
                        </div>
                    <% } %>

                    <!-- Write Review Form Card (Placed BELOW Reviews List) -->
                    <div class="bg-white border-2 border-stone-300 rounded-2xl p-6 sm:p-8 space-y-4 shadow-sm mt-8">
                        <h4 class="font-display font-extrabold text-base text-stone-900 flex items-center gap-2 border-b border-stone-200 pb-3">
                            <i data-lucide="edit-3" class="w-4 h-4 text-emerald-800"></i> Share Your Organic Harvest Review
                        </h4>

                        <form action="/product/<%= p.slug %>" method="POST" class="space-y-4 text-xs">
                            <input type="hidden" name="product_id" value="<%= p.id %>">
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="space-y-1.5">
                                    <label class="font-bold text-stone-900 block">Your Full Name *</label>
                                    <input type="text" name="rev_author" required placeholder="e.g. Rahul Sharma" class="w-full bg-stone-50 border border-stone-300 rounded-xl p-3 text-stone-900 focus:outline-none focus:ring-2 focus:ring-emerald-800 font-medium">
                                </div>
                                <div class="space-y-1.5">
                                    <label class="font-bold text-stone-900 block">Email Address *</label>
                                    <input type="email" name="rev_email" required placeholder="e.g. rahul@gmail.com" class="w-full bg-stone-50 border border-stone-300 rounded-xl p-3 text-stone-900 focus:outline-none focus:ring-2 focus:ring-emerald-800 font-medium">
                                </div>
                            </div>

                            <div class="space-y-1.5">
                                <label class="font-bold text-stone-900 block">Rating Stars *</label>
                                <select name="rev_rating" required class="bg-stone-50 border border-stone-300 rounded-xl p-3 text-amber-800 font-extrabold focus:outline-none">
                                    <option value="5">⭐⭐⭐⭐⭐ 5 Stars (Outstanding Organic Harvest)</option>
                                    <option value="4">⭐⭐⭐⭐ 4 Stars (Very High Quality)</option>
                                    <option value="3">⭐⭐⭐ 3 Stars (Good Quality)</option>
                                </select>
                            </div>

                            <div class="space-y-1.5">
                                <label class="font-bold text-stone-900 block">Detailed Review Comments *</label>
                                <textarea name="rev_comment" rows="3" required placeholder="Describe taste, crunch, freshness, packaging, or delivery experience..." class="w-full bg-stone-50 border border-stone-300 rounded-xl p-3 text-stone-900 focus:outline-none focus:ring-2 focus:ring-emerald-800 font-medium"></textarea>
                            </div>

                            <button type="submit" class="bg-emerald-900 hover:bg-emerald-950 text-amber-300 font-extrabold py-3 px-6 rounded-xl transition-all shadow-xs cursor-pointer border border-emerald-800">
                                Publish Customer Review
                            </button>
                        </form>
                    </div>

                </div>

            </div>

            <!-- Right 4 Cols: Desktop Sticky Floating Trust & Guarantee Box with Buy Now -->
            <div class="lg:col-span-4 space-y-4 lg:sticky lg:top-24">
                <!-- Sticky Buy Now Box -->
                <div class="bg-emerald-900 border-2 border-emerald-800 text-amber-300 rounded-2xl p-5 shadow-sm space-y-3">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <i data-lucide="zap" class="w-5 h-5 text-amber-300 fill-amber-300"></i>
                            <span class="font-extrabold text-sm uppercase tracking-wider text-amber-300">Express Checkout</span>
                        </div>
                        <span class="text-xs font-mono font-bold text-emerald-200">₹<span id="sidebar-price-display"><%= unitPrice.toFixed(2) %></span></span>
                    </div>
                    <form action="/checkout" method="POST" class="w-full space-y-2">
                        <input type="hidden" name="direct_buy" value="1">
                        <input type="hidden" name="product_id" value="<%= p.id %>">
                        <input type="hidden" id="selected-weight-input-sidebar" name="weight_variant" value="500 Grams Pack">
                        <input type="hidden" id="selected-price-input-sidebar" name="unit_price" value="<%= unitPrice %>">
                        <input type="hidden" id="selected-qty-input-sidebar" name="quantity" value="1">
                        <button type="submit" class="w-full bg-amber-400 hover:bg-amber-300 text-stone-950 font-display font-extrabold text-sm py-3.5 px-4 rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer border border-amber-300 uppercase tracking-wide">
                            <i data-lucide="zap" class="w-4 h-4 text-stone-950 fill-stone-950"></i>
                            <span>BUY NOW</span>
                        </button>
                    </form>
                    <p class="text-[10px] text-emerald-200 font-medium text-center flex items-center justify-center gap-1">
                        <i data-lucide="shield-check" class="w-3 h-3 text-amber-300"></i> Direct Instant Express Checkout
                    </p>
                </div>

                <div class="bg-white border-2 border-stone-300 rounded-2xl p-5 shadow-sm space-y-4">
                    <h4 class="font-display font-extrabold text-xs text-stone-900 uppercase tracking-wider border-b border-stone-200 pb-2.5 flex items-center gap-2">
                        <i data-lucide="shield-check" class="w-4 h-4 text-emerald-800"></i> Quality & Delivery Guarantees
                    </h4>
                    <div class="space-y-3 text-xs">
                        <div class="flex items-start gap-3 bg-stone-50 border border-stone-200 p-3 rounded-xl">
                            <i data-lucide="truck" class="w-5 h-5 text-emerald-800 shrink-0 mt-0.5"></i>
                            <div>
                                <p class="font-bold text-stone-900">Free Express Delivery</p>
                                <p class="text-[11px] text-stone-600">On orders > ₹500</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3 bg-stone-50 border border-stone-200 p-3 rounded-xl">
                            <i data-lucide="rotate-ccw" class="w-5 h-5 text-emerald-800 shrink-0 mt-0.5"></i>
                            <div>
                                <p class="font-bold text-stone-900">100% Freshness</p>
                                <p class="text-[11px] text-stone-600">7-Day Fresh Guarantee</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3 bg-stone-50 border border-stone-200 p-3 rounded-xl">
                            <i data-lucide="shield-check" class="w-5 h-5 text-emerald-800 shrink-0 mt-0.5"></i>
                            <div>
                                <p class="font-bold text-stone-900">Unbleached</p>
                                <p class="text-[11px] text-stone-600">Zero Chemicals</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3 bg-stone-50 border border-stone-200 p-3 rounded-xl">
                            <i data-lucide="award" class="w-5 h-5 text-emerald-800 shrink-0 mt-0.5"></i>
                            <div>
                                <p class="font-bold text-stone-900">Lab Certified</p>
                                <p class="text-[11px] text-stone-600">FSSAI Approved</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>

<script>
    var currentUnitBasePrice = <%= unitPrice %>;
    var currentRatingFilter = 'all';
    var visibleReviewCount = 10;

    function selectProductImage(idx, imgUrl, btnEl) {
        var mainImg = document.getElementById('main-product-img');
        if (mainImg) {
            mainImg.src = imgUrl;
        }

        var buttons = document.querySelectorAll('.thumbnail-btn');
        buttons.forEach(function(btn) {
            btn.classList.remove('border-emerald-800', 'ring-2', 'ring-emerald-600/30');
            btn.classList.add('border-stone-300');
        });

        if (btnEl) {
            btnEl.classList.remove('border-stone-300');
            btnEl.classList.add('border-emerald-800', 'ring-2', 'ring-emerald-600/30');
        }
    }

    function updateVariant(weightText, salePrice, mrpPrice, btnEl) {
        currentUnitBasePrice = parseFloat(salePrice);

        var buttons = document.querySelectorAll('.variant-btn');
        buttons.forEach(function(btn) {
            btn.classList.remove('border-emerald-800', 'bg-emerald-50', 'text-emerald-950');
            btn.classList.add('border-stone-300', 'bg-white', 'text-stone-900');
            var icon = btn.querySelector('[data-lucide="check-circle-2"]');
            if (icon) icon.remove();
        });

        if (btnEl) {
            btnEl.classList.remove('border-stone-300', 'bg-white', 'text-stone-900');
            btnEl.classList.add('border-emerald-800', 'bg-emerald-50', 'text-emerald-950');
        }

        var weightInput = document.getElementById('selected-weight-input');
        var weightInputSidebar = document.getElementById('selected-weight-input-sidebar');
        var priceInput = document.getElementById('selected-price-input');
        var priceInputSidebar = document.getElementById('selected-price-input-sidebar');
        var displaySale = document.getElementById('display-sale-price');
        var displayMrp = document.getElementById('display-mrp');

        if (weightInput) weightInput.value = weightText;
        if (weightInputSidebar) weightInputSidebar.value = weightText;
        if (priceInput) priceInput.value = salePrice;
        if (priceInputSidebar) priceInputSidebar.value = salePrice;
        if (displaySale) displaySale.innerText = '₹' + parseFloat(salePrice).toFixed(2);
        if (displayMrp) displayMrp.innerText = '₹' + parseFloat(mrpPrice).toFixed(2);

        updateTotalButtonPrice();
    }

    function adjustQty(delta) {
        var qtyInput = document.getElementById('qty-input');
        if (!qtyInput) return;
        var currentQty = parseInt(qtyInput.value) || 1;
        var newQty = currentQty + delta;
        if (newQty >= 1 && newQty <= 10) {
            qtyInput.value = newQty;
            var sidebarQtyInput = document.getElementById('selected-qty-input-sidebar');
            if (sidebarQtyInput) sidebarQtyInput.value = newQty;
            updateTotalButtonPrice();
        }
    }

    function updateTotalButtonPrice() {
        var qtyInput = document.getElementById('qty-input');
        var btnPriceDisplay = document.getElementById('btn-price-display');
        var sidebarPriceDisplay = document.getElementById('sidebar-price-display');
        var qty = parseInt(qtyInput ? qtyInput.value : 1) || 1;
        var total = currentUnitBasePrice * qty;
        if (btnPriceDisplay) {
            btnPriceDisplay.innerText = total.toFixed(2);
        }
        if (sidebarPriceDisplay) {
            sidebarPriceDisplay.innerText = total.toFixed(2);
        }
    }

    function switchTab(tabId) {
        var panels = document.querySelectorAll('.tab-panel');
        panels.forEach(function(panel) {
            panel.classList.add('hidden');
        });

        var activePanel = document.getElementById('tab-panel-' + tabId);
        if (activePanel) {
            activePanel.classList.remove('hidden');
        }

        var tabBtns = document.querySelectorAll('.tab-btn');
        tabBtns.forEach(function(btn) {
            btn.classList.remove('bg-emerald-900', 'text-amber-300', 'border-emerald-800', 'shadow-sm');
            btn.classList.add('bg-white', 'text-stone-800', 'border-stone-300');
        });

        var activeBtn = document.getElementById('tab-btn-' + tabId);
        if (activeBtn) {
            activeBtn.classList.remove('bg-white', 'text-stone-800', 'border-stone-300');
            activeBtn.classList.add('bg-emerald-900', 'text-amber-300', 'border-emerald-800', 'shadow-sm');
        }
    }

    function filterReviews(star, btnEl) {
        currentRatingFilter = star;
        visibleReviewCount = 10;

        var btns = document.querySelectorAll('.review-filter-btn');
        btns.forEach(function(b) {
            b.classList.remove('bg-emerald-900', 'text-amber-300', 'border-emerald-800', 'shadow-2xs');
            b.classList.add('bg-white', 'text-stone-800', 'border-stone-300');
        });

        if (btnEl) {
            btnEl.classList.remove('bg-white', 'text-stone-800', 'border-stone-300');
            btnEl.classList.add('bg-emerald-900', 'text-amber-300', 'border-emerald-800', 'shadow-2xs');
        }

        renderFilteredReviews();
    }

    function renderFilteredReviews() {
        var items = document.querySelectorAll('.review-card-item');
        var matching = [];

        items.forEach(function(card) {
            var rating = card.getAttribute('data-rating');
            if (currentRatingFilter === 'all' || rating == currentRatingFilter) {
                matching.push(card);
            }
            card.classList.add('hidden');
        });

        for (var i = 0; i < matching.length && i < visibleReviewCount; i++) {
            matching[i].classList.remove('hidden');
        }

        var loadMoreBox = document.getElementById('load-more-reviews-box');
        var visibleText = document.getElementById('visible-count-text');
        var totalText = document.getElementById('total-count-text');

        if (visibleText) visibleText.innerText = Math.min(visibleReviewCount, matching.length);
        if (totalText) totalText.innerText = matching.length;

        if (loadMoreBox) {
            if (matching.length > visibleReviewCount) {
                loadMoreBox.classList.remove('hidden');
            } else {
                loadMoreBox.classList.add('hidden');
            }
        }
    }

    function loadMoreReviews() {
        visibleReviewCount += 10;
        renderFilteredReviews();
    }
</script>

<%- include('partials/footer') %>
